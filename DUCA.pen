            },
            {
              "type": "text",
              "id": "fGC1L",
              "name": "Erick Martínez",
              "fill": "#36abb2ff",
              "textGrowth": "fixed-width",
              "width": 432,
              "content": "Erick Martínez",
              "fontFamily": "Raleway",
              "fontSize": 32,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "XJJGv",
              "name": "Es un especialista en diseño industrial y de productos que vincula la creatividad con la gestión operativa mediante metodologías ágiles. Con experiencia técnica en el sector farmacéutico y la docencia en la UCA, se enfoca en facilitar procesos de innovación y diseño estratégico para optimizar la producción y ayudar a las empresas a incorporar el diseño en su ADN organizacional.",
              "fill": "#000000ff",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Es un especialista en diseño industrial y de productos que vincula la creatividad con la gestión operativa mediante metodologías ágiles. \n\nCon experiencia técnica en el sector farmacéutico y la docencia en la UCA, se enfoca en facilitar procesos de innovación y diseño estratégico para optimizar la producción y ayudar a las empresas a incorporar el diseño en su ADN organizacional.",
              "fontFamily": "Raleway",
              "fontSize": 18,
              "fontWeight": "normal"
            }
          ]
        },
